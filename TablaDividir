Sub GenerarTablasConNombresParaAutoCAD()
    ' --- Configuración de Parámetros ---
    Dim filasPorTabla As Integer
    Dim nombreBase As String
    
    filasPorTabla = 60      ' Número de filas de datos por bloque
    nombreBase = "CUADRO"   ' Prefijo para el título y el nombre del rango
    
    Dim filaInicio As Long, filaFin As Long
    Dim colOrigen As Integer, colDestino As Integer
    Dim rSiguiente As Long, numTabla As Integer
    Dim ws As Worksheet
    Dim rngTotalTabla As Range
    
    Set ws = ActiveSheet
    filaInicio = 2  ' Fila donde comienzan los datos originales
    colOrigen = 1   ' Columna A (Origen)
    colDestino = 5  ' Columna E (Destino inicial)
    numTabla = 1
    
    ' Determinación del límite de datos
    filaFin = ws.Cells(ws.Rows.Count, colOrigen).End(xlUp).Row
    
    Application.ScreenUpdating = False
    
    For rSiguiente = filaInicio To filaFin Step filasPorTabla
        
        ' --- 1. Identificación Visual ---
        ' Utiliza la variable nombreBase para el título en la celda
        ws.Cells(1, colDestino).Value = nombreBase & " " & numTabla
        ws.Cells(1, colDestino).Font.Bold = True
        
        ' --- 2. Estructura de Encabezados ---
        ws.Cells(2, colDestino).Value = "ITEMS"
        ws.Range(ws.Cells(2, colDestino), ws.Cells(3, colDestino)).Merge
        
        ws.Cells(2, colDestino + 1).Value = "COORDENADAS"
        ws.Range(ws.Cells(2, colDestino + 1), ws.Cells(2, colDestino + 2)).Merge
        
        ws.Cells(3, colDestino + 1).Value = "LATITUD"
        ws.Cells(3, colDestino + 2).Value = "LONGITUD"
        
        ' --- 3. Transferencia de Datos ---
        ws.Range(ws.Cells(rSiguiente, colOrigen), ws.Cells(rSiguiente + filasPorTabla - 1, colOrigen + 2)).Copy _
            Destination:=ws.Cells(4, colDestino)
        
        ' --- 4. Definición de Rango y Formato ---
        Set rngTotalTabla = ws.Range(ws.Cells(2, colDestino), ws.Cells(3 + filasPorTabla, colDestino + 2))
        
        With rngTotalTabla.Borders
            .LineStyle = xlContinuous
            .Color = vbBlack
            .Weight = xlThin
        End With
        rngTotalTabla.BorderAround LineStyle:=xlContinuous, Weight:=xlMedium
        
        ' --- 5. Asignación de Nombre de Rango (AutoCAD) ---
        ' Se utiliza nombreBase para definir el nombre interno en el Administrador de Nombres
        On Error Resume Next
        ws.Names.Add Name:=nombreBase & numTabla, RefersTo:=rngTotalTabla
        On Error GoTo 0
        
        ' --- 6. Preparación de Siguiente Bloque ---
        colDestino = colDestino + 4
        numTabla = numTabla + 1
    Next rSiguiente
    
    Application.ScreenUpdating = True
    MsgBox "Proceso finalizado. Se han creado " & (numTabla - 1) & " bloques bajo el nombre '" & nombreBase & "'.", vbInformation
End Sub
